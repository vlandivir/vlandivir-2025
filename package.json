{
  "name": "vlandivir-2025",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "husky",
    "start": "nest start",
    "start:dev": "nest start --watch --entryFile main",
    "start:debug": "nest start --debug --watch --entryFile main",
    "prestart:prod": "npm run build",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "update-image-descriptions": "ts-node src/scripts/update-image-descriptions.ts --limit 5",
    "check-image-status": "ts-node src/scripts/check-image-status.ts",
    "test-collage": "ts-node src/scripts/test-collage-custom.ts",
    "telegram-app:dev": "npm run dev --prefix telegram-app",
    "telegram-app:build": "npm run build --prefix telegram-app",
    "telegram-app:preview": "npm run preview --prefix telegram-app",
    "email-ingest": "ts-node src/scripts/email-ingest-once.ts",
    "import-own-reels": "ts-node src/scripts/import-own-reels.ts",
    "generate-history-pdf": "ts-node src/scripts/generate-history-pdf.ts",
    "generate-history-pdf:html": "ts-node src/scripts/generate-history-html.ts",
    "generate-history-md": "ts-node src/scripts/generate-history-md.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.749.0",
    "@aws-sdk/lib-storage": "^3.749.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.3.1",
    "@telegram-apps/init-data-node": "^1.2.2",
    "canvas": "^3.1.2",
    "date-fns": "^4.1.0",
    "google-auth-library": "^10.9.0",
    "image-size": "^2.0.2",
    "imapflow": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.14",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.3",
    "telegraf": "^4.16.3",
    "uuid": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/image-size": "^0.7.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.3",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^6.3.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "overrides": {
    "esbuild": "^0.23.0"
  },
  "engines": {
    "node": ">=18.18"
  },
  "keywords": [],
  "webMiniApp": {
    "path": "web/mini-app"
  }
}
