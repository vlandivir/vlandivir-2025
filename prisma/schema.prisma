// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_CONNECTION_STRING")
}

model Note {
  id         Int       @id @default(autoincrement())
  content    String    @db.Text
  rawMessage Json      @db.JsonB
  noteDate   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt
  chatId     BigInt
  images     Image[]
  videos     Video[]

  @@index([chatId])
  @@index([noteDate])
}

model BotResponse {
  id        Int       @id @default(autoincrement())
  content   String    @db.Text
  noteId    Int
  chatId    BigInt
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([chatId])
  @@index([noteId])
}

model Image {
  id          Int      @id @default(autoincrement())
  url         String
  description String?  @db.Text
  note        Note?    @relation(fields: [noteId], references: [id])
  noteId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id          Int      @id @default(autoincrement())
  url         String
  description String?  @db.Text
  note        Note?    @relation(fields: [noteId], references: [id])
  noteId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Todo {
  id           Int       @id @default(autoincrement())
  key          String
  content      String    @db.Text
  createdAt    DateTime  @default(now())
  status       String    @default("new")
  completedAt  DateTime?
  priority     String?   @db.VarChar(1)
  dueDate      DateTime?
  snoozedUntil DateTime?
  tags         String[]
  contexts     String[]
  projects     String[]
  chatId       BigInt?

  @@index([key])
  @@index([chatId])
}

model Question {
  id           Int      @id @default(autoincrement())
  chatId       BigInt
  questionText String   @db.Text
  type         String   @default("text") // "text", "number", "binary"
  createdAt    DateTime @default(now())
  Answer       Answer[]

  @@index([chatId])
  @@index([createdAt])
}

model Answer {
  id           Int      @id @default(autoincrement())
  questionId   Int
  textAnswer   String?  @db.Text
  numberAnswer Float?
  answerDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  question     Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@index([answerDate])
  @@index([createdAt])
}

model TaskNote {
  id        Int      @id @default(autoincrement())
  key       String
  content   String   @db.Text
  createdAt DateTime @default(now())
  chatId    BigInt

  @@index([key])
  @@index([chatId])
}

model TaskImage {
  id          Int      @id @default(autoincrement())
  key         String
  url         String
  description String?  @db.Text
  chatId      BigInt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([chatId])
}

model MapPoint {
  id                     Int       @id @default(autoincrement())
  name                   String
  description            String?   @db.Text
  latitude               Float
  longitude              Float
  instagramUrl           String?
  instagramMeta          Json?     @db.JsonB
  instagramMetaUpdatedAt DateTime?
  tags                   String[]  @default([])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model MapTrack {
  id                     Int       @id @default(autoincrement())
  name                   String
  description            String?   @db.Text
  instagramUrl           String?
  instagramMeta          Json?     @db.JsonB
  instagramMetaUpdatedAt DateTime?
  tags                   String[]  @default([])
  points                 Json      @db.JsonB // [[lat, lng], ...]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model MapTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  emoji     String?
  createdAt DateTime @default(now())
}

model Reel {
  id                Int       @id @default(autoincrement())
  instagramUrl      String
  shortcode         String    @unique
  source            String    @default("notebook") // notebook | map
  status            String    @default("pending") // pending | ready | error
  error             String?   @db.Text
  title             String?
  description       String?   @db.Text
  author            String?
  publishedAt       DateTime?
  duration          Float?
  videoUrl          String? // copy in DO Spaces
  coverUrl          String? // copy in DO Spaces
  audioUrl          String? // extracted mp3 in DO Spaces
  transcript        String?   @db.Text
  transcriptClean   String?   @db.Text // LLM-corrected, split into replicas (one per line)
  transcriptLang    String?
  transcriptStatus  String    @default("none") // none | pending | ready | error
  transcriptError   String?   @db.Text
  frameUrls         String[]  @default([]) // 1 fps frames in DO Spaces
  visionDescription String?   @db.Text // LLM description of what happens on screen
  visionStatus      String    @default("none") // none | pending | ready | error
  visionError       String?   @db.Text
  tags              String[]  @default([]) // set by hand, shared MapTag dictionary
  meta              Json?     @db.JsonB // raw yt-dlp info
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
}

// Unified embeddings for semantic search over reels, notes and images.
// Rows are written/queried via raw SQL (pgvector); Prisma client can't
// handle the vector type directly.
model Embedding {
  id        Int                          @id @default(autoincrement())
  kind      String // reel | note | image
  refId     Int
  chatId    BigInt? // scope for private notes/images; null for reels
  content   String                       @db.Text // the text that was embedded
  embedding Unsupported("vector(1536)")
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  @@unique([kind, refId])
}

model ChatSettings {
  chatId    BigInt   @id
  timeZone  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
